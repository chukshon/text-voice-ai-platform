generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VoiceCategoryEnum {
  PREMADE @map("premade")
  CLONED  @map("cloned")
  CUSTOM  @map("custom")

  @@map("voice_category")
}

enum VoiceGenderEnum {
  MALE    @map("male")
  FEMALE  @map("female")
  NEUTRAL @map("neutral")

  @@map("voice_gender")
}

enum JobStatusEnum {
  PENDING    @map("pending")
  PROCESSING @map("processing")
  COMPLETED  @map("completed")
  FAILED     @map("failed")

  @@map("job_status")
}

enum JobTypeEnum {
  TTS   @map("tts")
  CLONE @map("clone")

  @@map("job_type")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique @db.VarChar(255)
  name         String   @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  apiKeys       ApiKey[]
  refreshTokens RefreshToken[]
  voices        Voice[]
  TtsJob        TtsJob[]

  @@map("users")
}

model ApiKey {
  id         String    @id @default(uuid())
  name       String    @db.VarChar(255)
  prefix     String    @db.VarChar(10)
  keyHash    String    @map("key_hash") @db.VarChar(255)
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Voice {
  id          String            @id @default(uuid())
  name        String            @db.VarChar(255)
  description String?
  category    VoiceCategoryEnum @default(PREMADE)
  language    String            @default("en") @db.VarChar(10)
  gender      VoiceGenderEnum   @default(NEUTRAL)
  accent      String?           @db.VarChar(100)
  previewUrl  String?           @map("preview_url") @db.VarChar(1024)
  isPublic    Boolean           @default(true) @map("is_public")
  metadata    Json              @default("{}")
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @default(now()) @map("updated_at") @db.Timestamptz(6)

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  VoiceSample VoiceSample[]
  TtsJob      TtsJob[]

  @@map("voices")
}

model VoiceSample {
  id          String   @id @default(uuid())
  fileName    String   @map("file_name") @db.VarChar(255)
  mimeType    String   @map("mime_type") @db.VarChar(100)
  sizeBytes   Int      @map("size_bytes")
  durationMs  Int?     @map("duration_ms")
  storagePath String   @map("storage_path") @db.VarChar(1024)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  voiceId String @map("voice_id")
  voice   Voice  @relation(fields: [voiceId], references: [id], onDelete: Cascade)

  @@map("voice_samples")
}

model TtsJob {
  id           String        @id @default(uuid())
  type         JobTypeEnum   @default(TTS)
  status       JobStatusEnum @default(PENDING)
  inputText    String?       @map("input_text")
  outputFileId String?       @map("output_file_id")
  error        String?
  metadata     Json          @default("{}")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)

  userId  String @map("user_id")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceId String @map("voice_id")
  voice   Voice  @relation(fields: [voiceId], references: [id])

  audioFile AudioFile[]

  @@map("tts_jobs")
}

model AudioFile {
  id          String   @id @default(uuid())
  fileName    String   @map("file_name") @db.VarChar(255)
  mimeType    String   @map("mime_type") @db.VarChar(100)
  sizeBytes   Int      @map("size_bytes")
  durationMs  Int?     @map("duration_ms")
  storagePath String   @map("storage_path") @db.VarChar(1024)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  jobId String @map("job_id")
  job   TtsJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("audio_files")
}
