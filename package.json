  "main": "index.js",
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "infra": "docker compose up -d postgres redis rabbitmq minio traefik",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:ps": "docker compose ps",
    "db:generate": "pnpm --filter @repo/db generate",
    "db:migrate:dev": "pnpm --filter @repo/db migrate:dev",
    "db:migrate:deploy": "pnpm --filter @repo/db migrate:deploy",
    "db:seed": "pnpm --filter @repo/db seed",
    "db:studio": "pnpm --filter @repo/db studio",
    "dev:auth": "pnpm --filter auth dev",
    "dev:voice": "pnpm --filter voice dev",
    "dev:worker": "pnpm --filter worker dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.2",
  "devDependencies": {
    "@types/node": "^25.5.2",
    "prettier": "^3.8.1",
    "prettier-plugin-prisma": "^5.0.0",
    "typescript": "^6.0.2"
  }
}
